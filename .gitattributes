*.so filter=lfs diff=lfs merge=lfs -text
*.aar filter=lfs diff=lfs merge=lfs -text
assets/cores/android/**/xray filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text

# Linux shell scripts must keep LF line endings even when checked out on
# Windows, otherwise bash refuses to run them.
*.sh text eol=lf
tools/cores/linux/* binary
